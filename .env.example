# Server Configuration
PORT=8000
SESSION_SECRET=a-very-long-and-secure-secret-32-chars-long

# Database Configuration (PostgreSQL)
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=waifu
DATABASE_URL=postgres://postgres:postgres@db:5432/waifu

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USER=
REDIS_PASSWORD=

# Discord Bot Configuration
DISCORD_TOKEN=your_bot_token_here

# Discord OAuth2 Configuration (for Login)
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
DISCORD_CALLBACK_URL=http://localhost:8000/auth/discord/callback
